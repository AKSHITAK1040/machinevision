# Required for VLM (YOLO->crop->GPT-4o). If missing, backend falls back to legacy heuristics.
OPENAI_API_KEY=

# Optional tuning
WORKER_COUNT=2
AI_SAMPLE_INTERVAL_SEC=2.0
AI_MAX_FRAMES=24
YOLO_MODEL=yolov8n.pt
YOLO_CONF=0.25
OPENAI_VLM_MODEL=gpt-4o-mini
VLM_MAX_CROPS=10

# Optional CORS
FRONTEND_ORIGIN=http://localhost:3000

